{
  "name": "diffy",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "codegen": "turbo codegen",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "turbo": "^2.9.14",
    "typescript": "6.0.3",
    "ultracite": "7.7.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm dlx ultracite fix"
    ],
    "*.rs": [
      "rustfmt --config-path apps/backend/rustfmt.toml"
    ]
  },
  "engines": {
    "node": ">=25.82"
  },
  "packageManager": "pnpm@11.3.0"
}
